# ============================================
# ZBot CLI 应用 Dockerfile
# ============================================
# ZBot 是一个命令行工具，与 Web 服务不同
# 它需要交互式运行，没有固定的服务端口

# --------------------------------------------
# 第一步：选择基础镜像
# --------------------------------------------
# 使用阿里云镜像加速
FROM docker.1ms.run/python:3.11-slim

# --------------------------------------------
# 第二步：设置工作目录
# --------------------------------------------
WORKDIR /app

# --------------------------------------------
# 第三步：安装系统依赖
# --------------------------------------------
# git: 某些功能可能需要
RUN apt-get update && apt-get install -y \
    git \
    && rm -rf /var/lib/apt/lists/*

# --------------------------------------------
# 第四步：复制依赖文件
# --------------------------------------------
# 先复制 requirements.txt（如果存在）
# 利用 Docker 缓存机制加速构建
COPY requirements.txt .

# --------------------------------------------
# 第五步：安装 Python 依赖
# --------------------------------------------
# 使用阿里云镜像源，更稳定
RUN if [ -f requirements.txt ]; then \
    pip install --no-cache-dir -r requirements.txt \
    -i https://mirrors.aliyun.com/pypi/simple/ \
    --trusted-host mirrors.aliyun.com; \
    fi

# --------------------------------------------
# 第六步：复制项目代码
# --------------------------------------------
COPY . .

# --------------------------------------------
# 第七步：安装 ZBot 包
# --------------------------------------------
# -e 表示可编辑模式，方便开发
RUN pip install -e . \
    -i https://mirrors.aliyun.com/pypi/simple/ \
    --trusted-host mirrors.aliyun.com

# --------------------------------------------
# 第八步：创建配置目录
# --------------------------------------------
# ZBot 的配置文件默认存储在 ~/.ZBot 目录
RUN mkdir -p /root/.ZBot

# --------------------------------------------
# 第九步：设置环境变量
# --------------------------------------------
ENV PYTHONUNBUFFERED=1

# --------------------------------------------
# 第十步：默认命令
# --------------------------------------------
# 显示帮助信息
CMD ["python", "-m", "ZBot", "--help"]
